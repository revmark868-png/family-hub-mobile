{
  "expo": {
    "name": "Family Hub",
    "slug": "family-hub-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "familyhub",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#fff7ed"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ccwu.hima.familyhub",
      "buildNumber": "1",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Family Hub needs photo library access so you can send photos and videos to your family memory wall.",
        "NSCameraUsageDescription": "Family Hub may use the camera to add new family memories.",
        "NSUserNotificationsUsageDescription": "Family Hub sends notifications for new family memories, invites, and display alerts."
      }
    },
    "android": {
      "package": "ccwu.hima.familyhub",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#fff7ed"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO",
        "POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "replace-with-eas-project-id"
      }
    }
  }
}
